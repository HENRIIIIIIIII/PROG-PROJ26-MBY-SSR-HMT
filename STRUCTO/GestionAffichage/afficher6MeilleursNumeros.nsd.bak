<?xml version="1.0" encoding="UTF-8"?>
<root xmlns:nsd="https://structorizer.fisch.lu" version="3.32-35" preRepeat="until " postFor="to" preReturn="return" postForIn="in" preWhile="while " output="OUTPUT" input="INPUT" preFor="for" preExit="exit" preLeave="leave" ignoreCase="true" preThrow="throw" preForIn="foreach" stepFor="by" namespace="" author="henmott" created="2026-05-18" changedby="fishe" changed="2026-06-07" origin="Structorizer 3.30-10" text="&#34;//----------------------------------------------------------------------------------//&#34;,&#34;// Nom de la fonction: afficher6MeilleursNumeros&#34;,&#34;// Entree / Sortie / I/O : I int valeurs[] (tableau des valeurs du Loto),&#34;,&#34;//                         I int nbValeurs (nombre de valeurs dans le tableau)&#34;,&#34;// Description: Affiche les NUMERO_A_JOUER valeurs les plus frequentes en ordre croissant&#34;,&#34;// Date de modification: le 01.06.26&#34;,&#34;// Remarque: Utilise un tri par insertion pour maintenir l'ordre croissant des occurrences&#34;,&#34;//----------------------------------------------------------------------------------//&#34;" comment="" color="ffffff" type="program" style="nice">
	<children>
		<for text="&#34;for (int i = 0; i &#60; NUMERO_A_JOUER; i++)&#34;" comment="&#34;Initialisation des tableaux avec -1 pour marquer les cases vides&#34;" counterVar="dummy_counter" startValue="(int i = 0; i &#60; NUMERO_A_JOUER; i++)" stepConst="1" style="FREETEXT" color="ffffff" disabled="0">
			<qFor color="ffffff">
			</qFor>
		</for>
		<for text="&#34;for (int i = 0; i &#60; nbValeurs; i++)&#34;" comment="&#34;Pour chaque valeur du loto, on calcule son nombre d'occurrences&#34;,&#34;puis on l'insere dans le bottom si elle a moins d'occurrences que le dernier du bottom&#34;" counterVar="dummy_counter" startValue="(int i = 0; i &#60; nbValeurs; i++)" stepConst="1" style="FREETEXT" color="ffffff" disabled="0">
			<qFor>
				<for text="&#34;for (int j = 0; j &#60; NUMERO_A_JOUER; j++)&#34;" comment="&#34;Verification que la valeur n'est pas deja dans le bottom&#34;" counterVar="dummy_counter" startValue="(int j = 0; j &#60; NUMERO_A_JOUER; j++)" stepConst="1" style="FREETEXT" color="ffffff" disabled="0">
					<qFor>
						<alternative text="&#34;if (numeros[j] == valeur)&#34;" comment="" color="ffffff" branch_colors="," disabled="0">
							<qTrue>
								<instruction text="&#34;est vrais dejaPresent &#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
							</qTrue>
							<qFalse>
								<instruction text="" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
							</qFalse>
						</alternative>
					</qFor>
				</for>
				<alternative text="&#34;if (!dejaPresent)&#34;" comment="&#34;Si la valeur n'est pas deja presente, on la place au bon endroit&#34;,&#34;dans le bottom en decalant les elements vers la droite&#34;" color="ffffff" branch_colors="," disabled="0">
					<qTrue>
						<for text="&#34;for (int j = 0; j &#60; NUMERO_A_JOUER; j++)&#34;" comment="" counterVar="dummy_counter" startValue="(int j = 0; j &#60; NUMERO_A_JOUER; j++)" stepConst="1" style="FREETEXT" color="ffffff" disabled="0">
							<qFor>
								<alternative text="&#34; if (occ &#62; occurrences[j])&#34;" comment="&#34;&#34;" color="ffffff" branch_colors="," disabled="0">
									<qTrue>
										<for text="&#34;for (int k = NUMERO_A_JOUER - 1; k &#62; j; k--)&#34;" comment="" counterVar="dummy_counter" startValue="(int k = NUMERO_A_JOUER - 1; k &#62; j; k--)" stepConst="1" style="FREETEXT" color="ffffff" disabled="0">
											<qFor>
												<instruction text="&#34;Decalage des numeros et de leurs occurrences associees&#34;" comment="&#34;&#34;" color="ffffff" rotated="0" disabled="0"></instruction>
											</qFor>
										</for>
										<instruction text="&#34;Insertion de la nouvelle valeur plus frequente&#34;" comment="&#34;&#34;" color="ffffff" rotated="0" disabled="0"></instruction>
									</qTrue>
									<qFalse>
										<instruction text="" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
									</qFalse>
								</alternative>
							</qFor>
						</for>
					</qTrue>
					<qFalse>
						<instruction text="" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
					</qFalse>
				</alternative>
			</qFor>
		</for>
		<for text="&#34;for (int i = 0; i &#60; NUMERO_A_JOUER - 1; i++)&#34;" comment="" counterVar="dummy_counter" startValue="(int i = 0; i &#60; NUMERO_A_JOUER - 1; i++)" stepConst="1" style="FREETEXT" color="ffffff" disabled="0">
			<qFor>
				<for text="&#34;for (int j = i + 1; j &#60; NUMERO_A_JOUER; j++)&#34;" comment="" counterVar="dummy_counter" startValue="(int j = i + 1; j &#60; NUMERO_A_JOUER; j++)" stepConst="1" style="FREETEXT" color="ffffff" disabled="0">
					<qFor>
						<alternative text="&#34;if (numeros[i] &#62; numeros[j] &amp;&amp; numeros[j] != -1)&#34;" comment="" color="ffffff" branch_colors="," disabled="0">
							<qTrue>
								<instruction text="&#34;On compare les numeros pour les mettre en ordre croissant, en ignorant les cases vides (-1)&#34;" comment="&#34;&#34;" color="ffffff" rotated="0" disabled="0"></instruction>
							</qTrue>
							<qFalse>
								<instruction text="" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
							</qFalse>
						</alternative>
					</qFor>
				</for>
			</qFor>
		</for>
		<call text="&#34;print MSG_6_MEILLEURS&#34;" comment="&#34;&#34;" color="ff80c0" disabled="0" ismethoddecl="0"></call>
		<for text="&#34;for (int i = 0; i &#60; NUMERO_A_JOUER; i++)&#34;" comment="" counterVar="dummy_counter" startValue="(int i = 0; i &#60; NUMERO_A_JOUER; i++)" stepConst="1" style="FREETEXT" color="ffffff" disabled="0">
			<qFor>
				<alternative text="&#34;if (numeros[i] != -1)&#34;" comment="" color="ffffff" branch_colors="," disabled="0">
					<qTrue>
						<instruction text="&#34;print numeros&#34;" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
					</qTrue>
					<qFalse>
						<instruction text="" comment="" color="ffffff" rotated="0" disabled="0"></instruction>
					</qFalse>
				</alternative>
			</qFor>
		</for>
	</children>
</root>